# ============================================================
# AST3 — Environment variables template
# Copy to .env and fill in real values.
# NEVER commit a filled-in .env to version control.
# ============================================================

# Django
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET
DJANGO_SETTINGS_MODULE=core.settings.prod
ALLOWED_HOSTS=your.domain.example

# Database (Postgres Pro Certified in production)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ast3
POSTGRES_USER=ast3
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DATABASE_URL=postgres://ast3:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/ast3

# Redis
REDIS_URL=redis://redis:6379/0

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=REPLACE
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# JWT (seconds)
JWT_ACCESS_TOKEN_LIFETIME=900
JWT_REFRESH_TOKEN_LIFETIME=604800

# Grafana
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# CORS
CORS_ALLOWED_ORIGINS=https://your.domain.example

# File uploads
MEDIA_ROOT=/app/media
MAX_UPLOAD_SIZE_MB=50

# Sentry (optional)
SENTRY_DSN=

# ClamAV socket (override for external clamd)
CLAMAV_TCP_ADDR=clamav
CLAMAV_TCP_PORT=3310
